# LLM API Configuration for GenesisX
# Copy this file to .env and fill in your credentials

# ============================================
# 🌟 国际主流API提供商
# ============================================

# --- Claude (Anthropic) ---
# LLM_API_BASE=https://api.anthropic.com/v1
# LLM_API_KEY=sk-ant-your-claude-key
# LLM_MODEL=claude-3-sonnet-20240229
# 说明: 需要通过 anthropic Python SDK 或 AWS Bedrock

# --- Claude via AWS Bedrock ---
# LLM_API_BASE=https://bedrock-runtime.amazonaws.com
# LLM_API_KEY=your-aws-access-key
# LLM_MODEL=anthropic.claude-3-sonnet-20240229-v1:0
# AWS_REGION=us-east-1

# --- OpenAI (GPT-4/GPT-3.5) ---
# LLM_API_BASE=https://api.openai.com/v1
# LLM_API_KEY=sk-your-openai-key
# LLM_MODEL=gpt-4o
# 可选模型: gpt-4o, gpt-4-turbo, gpt-3.5-turbo

# --- Azure OpenAI ---
# LLM_API_BASE=https://your-resource.openai.azure.com
# LLM_API_KEY=your-azure-api-key
# LLM_MODEL=gpt-4
# AZURE_DEPLOYMENT=your-deployment-name

# --- Google Gemini ---
# LLM_API_BASE=https://generativelanguage.googleapis.com/v1beta
# LLM_API_KEY=your-gemini-key
# LLM_MODEL=gemini-pro
# 可选模型: gemini-pro, gemini-ultra

# --- Cohere ---
# LLM_API_BASE=https://api.cohere.ai/v1
# LLM_API_KEY=your-cohere-key
# LLM_MODEL=command
# 可选模型: command, command-light

# ============================================
# 🇨🇳 国内API提供商
# ============================================

# --- DeepSeek (推荐 - 性价比高) ---
# LLM_API_BASE=https://api.deepseek.com/v1
# LLM_API_KEY=sk-your-deepseek-key
# LLM_MODEL=deepseek-chat
# 官网: https://platform.deepseek.com
# 价格: 输入 ¥0.001/千tokens, 输出 ¥0.002/千tokens

# --- 通义千问 (阿里云) ---
# LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_API_KEY=sk-your-qianwen-key
# LLM_MODEL=qwen-plus
# 可选模型: qwen-turbo, qwen-plus, qwen-max

# --- 文心一言 (百度) ---
# LLM_API_BASE=https://aip.baidubce.com/rpc/2.0/ai_custom/v1/wenxinworkshop/chat
# LLM_API_KEY=your-baidu-api-key
# LLM_MODEL=ernie-bot-4
# 可选模型: ernie-bot, ernie-bot-turbo

# --- 智谱清言 (ChatGLM) ---
# LLM_API_BASE=https://open.bigmodel.cn/api/paas/v4
# LLM_API_KEY=your-zhipu-key
# LLM_MODEL=glm-4
# 可选模型: glm-4, glm-3-turbo

# --- 讯飞星火 ---
# LLM_API_BASE=https://spark-api.xf-yun.com/v1
# LLM_API_KEY=your-xfei-key
# LLM_MODEL=generalv3.5

# --- Moonshot (Kimi) ---
# LLM_API_BASE=https://api.moonshot.cn/v1
# LLM_API_KEY=your-moonshot-key
# LLM_MODEL=moonshot-v1-8k
# 可选模型: moonshot-v1-8k, moonshot-v1-32k, moonshot-v1-128k

# --- 百川智能 ---
# LLM_API_BASE=https://api.baichuan-ai.com/v1
# LLM_API_KEY=your-baichuan-key
# LLM_MODEL=Baichuan2-Turbo

# --- Minimax (ABAB) ---
# LLM_API_BASE=https://api.minimax.chat/v1
# LLM_API_KEY=your-minimax-key
# LLM_MODEL=abab6.5s-chat

# ============================================
# 🔧 开源模型托管平台
# ============================================

# --- Hugging Face Inference API ---
# LLM_API_BASE=https://api-inference.huggingface.co
# LLM_API_KEY=your-hf-token
# LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# --- Replicate ---
# LLM_API_BASE=https://api.replicate.com/v1
# LLM_API_KEY=your-replicate-key
# LLM_MODEL=meta/meta-llama-3-70b-instruct

# --- Together AI ---
# LLM_API_BASE=https://api.together.xyz/v1
# LLM_API_KEY=your-together-key
# LLM_MODEL=mistralai/Mixtral-8x7B-Instruct-v0.1

# ============================================
# 🏠 本地部署方案 (免费)
# ============================================

# --- Ollama (推荐 - 最简单) ---
# LLM_API_BASE=http://localhost:11434/v1
# LLM_API_KEY=not-needed
# LLM_MODEL=llama3
# 安装: https://ollama.ai
# 可用模型: llama3, mistral, qwen2, deepseek-coder, codellama
# 使用: ollama pull llama3

# --- LM Studio ---
# LLM_API_BASE=http://localhost:1234/v1
# LLM_API_KEY=not-needed
# LLM_MODEL=local-model
# 下载: https://lmstudio.ai

# --- LocalAI ---
# LLM_API_BASE=http://localhost:8080/v1
# LLM_API_KEY=not-needed
# LLM_MODEL=ggml-gpt4all-j

# --- vLLM ---
# LLM_API_BASE=http://localhost:8000/v1
# LLM_API_KEY=not-needed
# LLM_MODEL=meta-llama/Meta-Llama-3-8B

# --- Text Generation WebUI (oobabooga) ---
# LLM_API_BASE=http://localhost:5000/v1
# LLM_API_KEY=not-needed
# LLM_MODEL=local-model

# ============================================
# 🌐 其他代理/中转服务
# ============================================

# --- OpenRouter (聚合多个模型) ---
# LLM_API_BASE=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-your-openrouter-key
# LLM_MODEL=anthropic/claude-3-haiku
# 说明: 可访问Claude、GPT-4等多种模型

# --- Retry (API代理) ---
# LLM_API_BASE=https://api.retry.chat/v1
# LLM_API_KEY=sk-your-retry-key
# LLM_MODEL=openai/gpt-4

# --- API2D (OpenAI代理) ---
# LLM_API_BASE=https://oa.api2d.net/v1
# LLM_API_KEY=your-api2d-key
# LLM_MODEL=gpt-4

# --- CloseAI (转发服务) ---
# LLM_API_BASE=https://api.closeai-proxy.xyz/v1
# LLM_API_KEY=sk-your-closeai-key
# LLM_MODEL=gpt-4

# ============================================
# ⚙️ 自定义配置 (如果没有上面的适用)
# ============================================
# Fill in your custom API details:

# LLM_API_BASE=https://your-api-url/v1
# LLM_API_KEY=your-api-key-here
# LLM_MODEL=your-model-name

# ============================================
# 📊 可选参数
# ============================================
LLM_TEMPERATURE=0.7          # 创造性 (0.0-2.0，越高越随机)
LLM_MAX_TOKENS=2000          # 最大回复长度
LLM_TOP_P=0.9               # 核采样参数
LLM_FREQUENCY_PENALTY=0.0    # 频率惩罚
LLM_PRESENCE_PENALTY=0.0     # 存在惩罚

# ============================================
# 📖 使用说明
# ============================================
# 1. 复制此文件: cp llm_config.env.example .env
# 2. 取消注释(去掉#)一个API配置
# 3. 填入你的API密钥
# 4. 保存文件
# 5. 运行: python chat_interactive.py
#
# 推荐选择:
# - 新手: DeepSeek 或 Ollama (本地)
# - 追求质量: Claude 或 GPT-4
# - 预算有限: 通义千问 或 DeepSeek
# - 完全免费: Ollama (本地运行)
# ============================================
